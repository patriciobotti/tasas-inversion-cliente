{
  "version": 2,
  "framework": null,
  "builds": [
    { "src": "public_app/**", "use": "@vercel/static" },
    { "src": "api/recomendar.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/recomendar", "dest": "/api/recomendar.js" },
    { "src": "/(.*)", "dest": "/public_app/$1" }
  ]
}
